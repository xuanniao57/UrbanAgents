# UrbanAgent Environment Configuration
# Copy this file to .env and fill in the API keys you plan to use.
# At minimum, set ONE provider's API key (e.g., QWEN_API_KEY or OPENAI_API_KEY).

# ── LLM Provider ──
# Supported: qwen, openai, deepseek, kimi
LLM_PROVIDER=qwen
LLM_MODEL=qwen-plus

# ── Qwen (DashScope) ──
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── OpenAI ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── DeepSeek ──
Deepseek_API_KEY=
Deepseek_API_BASE=https://api.deepseek.com
Deepseek_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ── Kimi (Moonshot) ──
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-auto
KIMI_CODE_API_KEY=
KIMI_CODE_API_BASE=https://api.moonshot.cn/v1
KIMI_CODE_MODEL=moonshot-v1-auto

# ── Map API (optional, for geocoding) ──
AMAP_API_KEY=
