# Copy this file to env/kimi_code.env and fill in your own Kimi Code key.
# Do not commit, zip, or send env/kimi_code.env to collaborators.

# Required. Use the Kimi Code API key, not a Moonshot CN chat-completions key.
KIMI_CODE_API_KEY=replace_with_your_kimi_code_api_key

# Compatibility aliases used by different Urban-Hermes provider adapters.
# Keep these equal to KIMI_CODE_API_KEY unless your runtime explicitly says otherwise.
KIMI_API_KEY=replace_with_your_kimi_code_api_key
KIMI_CODING_API_KEY=replace_with_your_kimi_code_api_key

# Leave empty for the Kimi Code provider. Do not set this to https://api.moonshot.cn/v1.
KIMI_BASE_URL=

# Tested provider/model pair for the Case2 package.
HERMES_PROVIDER=kimi-coding
HERMES_MODEL=kimi-for-coding
