{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urbanworkflowbench-v1.schema.json",
  "title": "UrbanWorkflowBench v1 Manifest",
  "type": "object",
  "required": ["benchmark", "version", "created_at", "cases"],
  "properties": {
    "benchmark": {"type": "string"},
    "version": {"type": "string"},
    "created_at": {"type": "string"},
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "suite", "protocol", "capability"],
        "properties": {
          "case_id": {"type": "string"},
          "suite": {"type": "string"},
          "protocol": {
            "type": "string",
            "enum": ["agent_task", "dual_space_probe", "memory_probe"]
          },
          "capability": {"type": "string"},
          "source": {"type": "string"},
          "task": {"type": "object"},
          "evaluation": {"type": "object"},
          "features": {"type": "object"},
          "expected_relation": {"type": "string"},
          "memory_seed": {
            "type": "array",
            "items": {"type": "object"}
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}