{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urbanworkflowbench-v1_2.schema.json",
  "title": "UrbanWorkflowBench v1.2 Manifest",
  "type": "object",
  "required": ["benchmark", "version", "created_at", "cases"],
  "properties": {
    "benchmark": {"type": "string"},
    "version": {"type": "string"},
    "created_at": {"type": "string"},
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "config": {"type": "object"},
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "suite", "protocol", "capability"],
        "properties": {
          "case_id": {"type": "string"},
          "suite": {"type": "string"},
          "protocol": {
            "type": "string",
            "enum": [
              "agent_task",
              "dual_space_probe",
              "memory_probe",
              "tool_orchestration_probe",
              "hitl_checkpoint_probe",
              "open_workflow_planning"
            ]
          },
          "capability": {"type": "string"},
          "source": {"type": "string"},
          "tier": {"type": "string"},
          "tier_rank": {"type": "integer"},
          "task": {"type": "object"},
          "task_seed": {"type": "object"},
          "perception": {"type": "object"},
          "evaluation": {"type": "object"},
          "features": {"type": "object"},
          "expected_relation": {"type": "string"},
          "memory_seed": {
            "type": "array",
            "items": {"type": "object"}
          },
          "tool_steps": {
            "type": "array",
            "items": {"type": "object"}
          },
          "workflow_expectation": {"type": "object"},
          "checkpoint_flow": {
            "type": "array",
            "items": {"type": "object"}
          },
          "state": {"type": "object"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
