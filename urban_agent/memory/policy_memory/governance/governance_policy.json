      "read_roles": [
        "perception",
        "analyst",
        "manager"
      ],
      "write_roles": [
        "perception"
      ]
    },
    {
      "name": "analyze_connectivity",
      "description": "Analyze road-network connectivity metrics.",
      "category": "Data Understanding",
      "read_roles": [
        "analyst",
        "perception"
      ],
      "write_roles": [
        "analyst"
      ]
    },
    {
      "name": "measure_accessibility",
      "description": "Measure accessibility between origins and destinations.",
      "category": "Data Understanding",
      "read_roles": [
        "analyst",
        "perception"
      ],
      "write_roles": [
        "analyst"
      ]
    },
    {
      "name": "calculate_density",
      "description": "Compute density and morphology metrics.",
      "category": "Data Understanding",
      "read_roles": [
        "analyst",
        "perception"
      ],
      "write_roles": [
        "analyst"
      ]
    },
    {
      "name": "build_topology",
      "description": "Build topology relations from spatial features.",
      "category": "Data Understanding",
      "read_roles": [
        "analyst",
        "perception"
      ],
      "write_roles": [
        "analyst"
      ]
    },
    {
      "name": "export_geojson",
