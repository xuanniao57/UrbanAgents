{
  "policy_id": "default_governance_policy",
  "summary": "Default role access matrix and lean core tool inventory for UrbanAgent governance.",
  "triggers": [
    "governance",
    "tool inventory",
    "access matrix",
    "permissions"
  ],
  "scope": "resource_governance",
  "access_matrix": {
    "planner": {
      "System Interaction": "R",
      "Data Understanding": "R",
      "Domain Knowledge": "R"
    },
    "perception": {
      "System Interaction": "R/W",
      "Data Understanding": "R/W",
      "Domain Knowledge": "R"
    },
    "analyst": {
      "System Interaction": "R",
      "Data Understanding": "R/W",
      "Domain Knowledge": "R/W"
    },
    "cartographer": {
      "System Interaction": "R/W",
      "Data Understanding": "R",
      "Domain Knowledge": "R"
    },
    "reporter": {
      "System Interaction": "R",
      "Data Understanding": "R",
      "Domain Knowledge": "R"
    },
    "spatial_reviewer": {
      "System Interaction": "R",
      "Data Understanding": "R",
      "Domain Knowledge": "R"
    },
    "quality_controller": {
      "System Interaction": "R",
      "Data Understanding": "R",
      "Domain Knowledge": "R"
    },
    "manager": {
      "System Interaction": "R/W",
      "Data Understanding": "R/W",
      "Domain Knowledge": "R/W"
    }
  },
  "tool_inventory": [
    {
      "name": "fetch_osm_data",
      "description": "Acquire OpenStreetMap context for a study area.",
