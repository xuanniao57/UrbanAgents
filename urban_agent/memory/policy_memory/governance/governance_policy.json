      "read_roles": [
        "*"
      ],
      "write_roles": [
        "cartographer",
        "analyst"
      ]
    },
    {
      "name": "generate_svg_overlay",
      "description": "Generate geospatially aligned SVG overlays.",
      "category": "Domain Knowledge",
      "read_roles": [
        "cartographer",
        "reporter"
      ],
      "write_roles": [
        "cartographer"
      ]
    },
    {
      "name": "generate_measurement_report",
      "description": "Generate measurement report artifacts.",
      "category": "Domain Knowledge",
      "read_roles": [
        "reporter",
        "analyst"
