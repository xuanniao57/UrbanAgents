{
  "suite_name": "degim_urban_agent_iterative",
  "description": "快速迭代验证：DeGIM + Urban Agent 核心链路",
  "tests": [
    {
      "name": "degim_single_run",
      "command": "python run_degim.py",
      "timeout_seconds": 600,
      "required_artifacts": [
        "outputs/degim_report.json",
        "outputs/visualization.html"
      ]
    },
    {
      "name": "degim_batch_validation",
      "command": "python run_batch_validation.py",
      "timeout_seconds": 1800,
      "required_artifacts": [
        "outputs/batch_validation/batch_summary.json"
      ]
    },
    {
      "name": "urban_agent_local_smoke",
      "command": "python test_urban_agent_local.py",
      "timeout_seconds": 600,
      "required_artifacts": []
    }
  ]
}
